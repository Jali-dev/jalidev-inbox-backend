# ── Supabase ─────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Telegram ──────────────────────────────────────
# Get from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=

# ── Meta / WhatsApp Cloud API ─────────────────────
# Leave empty until you have Meta Business credentials
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_APP_SECRET=
META_VERIFY_TOKEN=jalidev-inbox-verify

# ── n8n ───────────────────────────────────────────
# WF-06 webhook URL
N8N_INBOX_WEBHOOK_URL=https://n8n.jalidev.online/webhook/inbox-ai-reply
# Secret key shared between FastAPI and n8n (any random string)
N8N_CALLBACK_KEY=change-me-to-a-random-secret

# ── FastAPI ───────────────────────────────────────
# Public base URL of this server (used to auto-register Telegram webhook)
FASTAPI_BASE_URL=https://api.jalidev.online
